# Persistência do estado (Upstash Redis — tier grátis em upstash.com/redis)
# Sem isto, o site funciona mas o estado só dura enquanto o servidor não reinicia.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Segredo pedido no payload dos webhooks do TradingView, para ninguém mais conseguir
# escrever no teu estado ao vivo. Define algo aleatório.
WEBHOOK_SECRET=

# Opcional — auto-preencher notícias no Weekly Outlook via financialmodelingprep.com (tier grátis)
FMP_API_KEY=

# Preencher quando ligares a API do Tradovate para dados reais (ver README)
TRADOVATE_CID=
TRADOVATE_SECRET=
