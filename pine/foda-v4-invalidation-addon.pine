// ═══════════════════════════════════════════════════════════
// ➕ ADICIONAR ISTO AO FINAL DO TEU SCRIPT "FODA v4"
// (depois do bloco de alertcondition existente, antes da TABELA)
// Invalida a zona só se uma candle FECHAR fora dela (wick não conta)
// ═══════════════════════════════════════════════════════════

invalid_ny_top  = ny_on  and not na(last_hi_ny)  and close > last_hi_ny
invalid_ny_bot  = ny_on  and not na(last_lo_ny)  and close < last_lo_ny
invalid_lon_top = lon_on and not na(last_hi_lon) and close > last_hi_lon
invalid_lon_bot = lon_on and not na(last_lo_lon) and close < last_lo_lon
invalid_tok_top = tok_on and not na(last_hi_tok) and close > last_hi_tok
invalid_tok_bot = tok_on and not na(last_lo_tok) and close < last_lo_tok

alertcondition(invalid_ny_top or invalid_ny_bot,   "New York — Zona Invalidada (fecho)", "FODA: fecho fora da zona New York")
alertcondition(invalid_lon_top or invalid_lon_bot, "London — Zona Invalidada (fecho)",   "FODA: fecho fora da zona London")
alertcondition(invalid_tok_top or invalid_tok_bot, "Tokyo — Zona Invalidada (fecho)",    "FODA: fecho fora da zona Tokyo")
